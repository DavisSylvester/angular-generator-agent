# =============================================================================
# angular-generator-agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama

# --- Ollama (local or cloud) ------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# OLLAMA_API_KEY=            # Optional — only for cloud Ollama (api.ollama.com)

# --- OpenAI ------------------------------------------------------------------
# OPENAI_API_KEY=sk-...      # Required if LLM_PROVIDER=openai

# --- Anthropic ---------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...  # Required if LLM_PROVIDER=anthropic

# --- Pipeline Configuration --------------------------------------------------
MAX_FIX_ITERATIONS=5         # Max fix iterations per task (1–20)
MAX_CONCURRENCY=4            # Parallel task limit (1–8)
LLM_TIMEOUT_MS=1800000       # LLM call timeout in ms (default: 30 min)
WORKSPACE_DIR=.workspace     # Output directory for runs

# --- Cost Controls -----------------------------------------------------------
TASK_COST_LIMIT=3.00         # Max cost per task in USD (aborts if exceeded)

# --- Google Stitch (design generation) ---------------------------------------
# Stitch uses Gemini via GOOGLE_API_KEY to generate design prompts,
# then submits them to stitch.withgoogle.com via Playwright.
# Always generates 5 designs varying in color scheme, approach, and pattern.
# Design #4 is always an AI-Embedded Command Palette variant.
# Every design starts with a landing page.
STITCH_DESIGN_COUNT=5        # Number of Stitch designs (min 5)

# --- Design Search (Dribbble) ------------------------------------------------
# Dribbble API token (recommended — more reliable than Playwright scraping).
# Get one at: https://dribbble.com/account/applications
# If not set, falls back to Playwright scraper.
# DRIBBBLE_ACCESS_TOKEN=
DRIBBBLE_RESULT_COUNT=5      # Minimum Dribbble designs to scrape (min 5)

# --- Build Validation (Playwright) -------------------------------------------
PLAYWRIGHT_VALIDATION_ELEMENTS=5  # Random elements to verify on built page

# --- Notifications (optional) ------------------------------------------------
# TELEGRAM_BOT_TOKEN=        # Telegram bot token for status updates
# TELEGRAM_CHAT_ID=          # Telegram chat ID for notifications
# NOTIFICATION_INTERVAL_MS=300000  # Notification interval (default: 5 min)

# --- Tracing (optional) -----------------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=angular-generator-agent
